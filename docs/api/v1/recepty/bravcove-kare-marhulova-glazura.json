ji na vysokom ohni opekaj 3–4 minúty z každej strany bez hýbania, kým nechytí zlatohnedú kôrku.","popis":""},{"nadpis":"Karé nechaj 3 minúty odpočinúť, potom nakrájaj na plátky.","popis":""},{"nadpis":"Na tanier daj ryžu, navrch plátky karé a lyžicu teplého marhuľového chutney.","popis":""}],"nutricne":{"kcal":520,"bielkoviny_g":32,"sacharidy_g":58,"tuky_g":16},"alergeny":["horcica"],"vegetarianske":false,"veganske":false,"sezonne_suroviny":[{"id":"marhule","mesiace":[6,7,8]}],"ceny_za_porciu":[{"obchod":"BILLA","cena_za_porciu":1.24,"usetris_za_porciu":1.0,"napar_surovin":10,"z_letaku":6,"odhadom":4,"spolu_surovin":10,"spolahlive":true,"platnost_od":"2026-07-17","platnost_do":"2026-07-19","nakup":[{"id":"bravcove-kare","surovina":"bravčové karé","kupit":"Bravčové karé bez kosti","zdroj_ceny":"letak","balenie":"cena za 1 kg","balenie_qty":1000,"balenie_jednotka":"g","cena_balenia":2.89,"povodna_cena":6.69,"akcia":true,"podmienka":"chladené, pultový predaj, víkendová akcia","trvanlivost":"cerstve","cena_v_recepte":0.92,"usetris_v_recepte":1.22,"mnozstvo_g":320},{"id":"marhule","surovina":"marhule","kupit":"Marhule","zdroj_ceny":"letak","balenie":"1 kg","balenie_qty":1000.0,"balenie_jednotka":"g","cena_balenia":1.99,"povodna_cena":3.99,"akcia":true,"podmienka":"voľné","trvanlivost":"cerstve","cena_v_recepte":0.5,"usetris_v_recepte":0.5,"mnozstvo_g":250},{"id":"cibula","surovina":"cibuľa","kupit":"Cibuľa žltá Chute Slovenska","zdroj_ceny":"letak","balenie":"1 kg","balenie_qty":1000.0,"balenie_jednotka":"g","cena_balenia":0.69,"povodna_cena":0.99,"akcia":true,"podmienka":"voľná","trvanlivost":"trvanlive","cena_v_recepte":0.15,"usetris_v_recepte":0.07,"mnozstvo_g":220},{"id":"zazvor","surovina":"zázvor","kupit":null,"zdroj_ceny":"bezna","balenie":"100 g","balenie_qty":100.0,"balenie_jednotka":"g","cena_balenia":0.6,"povodna_cena":null,"akcia":false,"podmienka":null,"trvanlivost":"cerstve","cena_v_recepte":0.03,"usetris_v_recepte":null,"mnozstvo_g":5},{"id":"ryza","surovi