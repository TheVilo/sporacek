{"slug":"svieckova-na-smotane-ryza","nazov":"Sviečková na smotane s ryžou","porcie":2,"cas_pripravy":"3 hodiny (z toho 4-6 hodín marinovania vopred)","foto_url":"https://raw.githubusercontent.com/TheVilo/sporacek/main/fotky/svieckova-na-smotane-ryza.jpg","tagy":["večera","hovädzie","sýte"],"suroviny":[{"nazov":"Hovädzia sviečkovica","mnozstvo":"500 g","id":"hovadzia-svieckovica","qty":500.0,"jednotka":"g","mnozstvo_g":500},{"nazov":"Mrkva","mnozstvo":"200 g","id":"mrkva","qty":200.0,"jednotka":"g","mnozstvo_g":200},{"nazov":"Zeler","mnozstvo":"100 g","id":"zeler","qty":100.0,"jednotka":"g","mnozstvo_g":100},{"nazov":"Cibuľa","mnozstvo":"1 ks","id":"cibula","qty":1.0,"jednotka":"ks","mnozstvo_g":110},{"nazov":"Maslo","mnozstvo":"30 g","id":"maslo","qty":30.0,"jednotka":"g","mnozstvo_g":30},{"nazov":"Horčica","mnozstvo":"1 ČL","id":"horcica","qty":5.0,"jednotka":"g","mnozstvo_g":5},{"nazov":"Ocot","mnozstvo":"1 ČL","id":"ocot","qty":5.0,"jednotka":"ml","mnozstvo_g":5},{"nazov":"Bujón (kocka)","mnozstvo":"1 ks","id":"bujon","qty":1.0,"jednotka":"ks","mnozstvo_g":null},{"nazov":"Smotana na varenie","mnozstvo":"200 ml","id":"smotana-na-varenie","qty":200.0,"jednotka":"ml","mnozstvo_g":200},{"nazov":"Bobkový list","mnozstvo":"2 ks","id":"bobkovy-list","qty":2.0,"jednotka":"ks","mnozstvo_g":null},{"nazov":"Ryža","mnozstvo":"150 g","id":"ryza","qty":150.0,"jednotka":"g","mnozstvo_g":150},{"nazov":"Brusnicová omáčka","mnozstvo":"2 PL (na podávanie)","id":"brusnicova-omacka","qty":30.0,"jednotka":"g","mnozstvo_g":30},{"nazov":"Soľ, čierne korenie","mnozstvo":"—","id":"cierne-korenie","qty":2,"jednotka":"g","mnozstvo_g":2}],"postup":["Mrkvu, zeler a cibuľu nastrúhaj nahrubo. Polovicu daj na dno hrnca, na ňu polož mäso, zalej rozpusteným maslom, navrch daj zvyšnú zeleninu. Prikry a nechaj marinovať v chladničke aspoň 4–6 hodín, ideálne cez noc.","Mäso vyber zo zeleniny, osuš, na panvici opeč zo všetkých strán dozlata. Na výpeku opeč aj zeleninu dozlata.","Do hrnca s opečenou zeleninou vmiešaj horčicu a ocot, minútu opraž, potom prilej 500 ml vody s bujónom. Pridaj bobkový list.","Vlož opečené mäso späť, prikry a duste na miernom ohni (alebo v rúre na 180 °C) 1,5–2 hodiny, kým mäso nie je mäkké.","Mäso vyber, zeleninovú omáčku rozmixuj dohladka, precedi cez sitko, vmiešaj smotanu a prehrej (nevar prudko).","Mäso nakrájaj na plátky, zalej horúcou omáčkou, podávaj s uvarenou ryžou a lyžicou brusnicovej omáčky."],"nutricne":{"kcal":520,"bielkoviny_g":38,"sacharidy_g":40,"tuky_g":22},"alergeny":["horcica","laktoza","zeler"],"vegetarianske":false,"veganske":false,"sezonne_suroviny":[{"id":"mrkva","mesiace":[6,7,8,9,10]},{"id":"zeler","mesiace":[9,10,11]}],"ceny_za_porciu":[{"obchod":"Kaufland","cena_za_porciu":1.0,"usetris_za_porciu":0.26,"napar_surovin":9,"z_letaku":5,"odhadom":4,"spolu_surovin":13,"spolahlive":false,"platnost_od":"2026-07-16","platnost_do":"2026-07-22","nakup":[{"id":"cibula","surovina":"cibuľa","kupit":"Cibuľa červená","zdroj_ceny":"letak","balenie":"500 g balenie (=1 kg 0,98)","balenie_qty":500.0,"balenie_jednotka":"g","cena_balenia":0.49,"povodna_cena":0.79,"akcia":true,"podmienka":null,"trvanlivost":"trvanlive","cena_v_recepte":0.11,"usetris_v_recepte":0.07,"mnozstvo_g":110},{"id":"maslo","surovina":"maslo","kupit":"Maslo 82%","zdroj_ceny":"letak","balenie":"200 g (=1 kg 8,95 bežná)","balenie_qty":200.0,"balenie_jednotka":"g","cena_balenia":0.48,"povodna_cena":1.79,"akcia":true,"podmienka":"vyžaduje aktiváciu kupónu (10 bodov) + Kaufland Card, max 10 ks, nákup nad 20 €","trvanlivost":"cerstve","cena_v_recepte":0.07,"usetris_v_recepte":0.2,"mnozstvo_g":30},{"id":"horcica","surovina":"horčica","kupit":"Horčica","zdroj_ceny":"letak","balenie":"350 g (=1 kg 2,26 s Kaufland Card)","balenie_qty":350.0,"balenie_jednotka":"g","cena_balenia":0.79,"povodna_cena":[0.89,1.15],"akcia":true,"podmienka":null,"trvanlivost":"trvanlive","cena_v_recepte":0.01,"usetris_v_recepte":null,"mnozstvo_g":5},{"id":"ocot","surovina":"ocot","kupit":nu