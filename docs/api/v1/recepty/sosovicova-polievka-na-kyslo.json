u, čiernym korením a octom do príjemne nakyslej chuti. Vyber bobkový list a podávaj s chlebom."],"nutricne":{"kcal":470,"bielkoviny_g":24,"sacharidy_g":55,"tuky_g":16},"alergeny":["laktoza","lepok"],"vegetarianske":false,"veganske":false,"sezonne_suroviny":[],"ceny_za_porciu":[{"obchod":"Tesco supermarket","cena_za_porciu":0.88,"usetris_za_porciu":0.12,"napar_surovin":9,"z_letaku":2,"odhadom":7,"spolu_surovin":11,"spolahlive":true,"platnost_od":"2026-07-15","platnost_do":"2026-07-21","nakup":[{"id":"sosovica","surovina":"šošovica","kupit":null,"zdroj_ceny":"bezna","balenie":"500 g","balenie_qty":500.0,"balenie_jednotka":"g","cena_balenia":1.6,"povodna_cena":null,"akcia":false,"podmienka":null,"trvanlivost":"trvanlive","cena_v_recepte":0.64,"usetris_v_recepte":null,"mnozstvo_g":200},{"id":"zemiaky","surovina":"zemiaky","kupit":null,"zdroj_ceny":"bezna","balenie":"1 kg","balenie_qty":1000.0,"balenie_jednotka":"g","cena_balenia":1.0,"povodna_cena":null,"akcia":false,"podmienka":null,"trvanlivost":"trvanlive","cena_v_recepte":0.3,"usetris_v_recepte":null,"mnozstvo_g":300},{"id":"cibula","surovina":"cibuľa","kupit":null,"zdroj_ceny":"bezna","balenie":"1 kg","balenie_qty":1000.0,"balenie_jednotka":"g","cena_balenia":1.0,"povodna_cena":null,"akcia":false,"podmienka":null,"trvanlivost":"trvanlive","cena_v_recepte":0.11,"usetris_v_recepte":null,"mnozstvo_g":110},{"id":"cesnak","surovina":"cesnak","kupit":null,"zdroj_ceny":"bezna","balenie":"100 g","balenie_qty":100.0,"balenie_jednotka":"g","cena_balenia":0.5,"povodna_cena":null,"akcia":false,"podmienka":null,"trvanlivost":"trvanlive","cena_v_recepte":0.05,"usetris_v_recepte":null,"mnozstvo_g":10},{"id":"smotana-na-varenie","surovina":"smotana na varenie","kupit":"Rajo smotana na šľahanie 33 %","zdroj_ceny":"letak","balenie":"250 ml (1 l = 4,76)","balenie_qty":250.0,"balenie_jednotka":"ml","cena_balenia":1.19,"povodna_cena":1.79,"akcia":true,"podmienka":null,"trvanlivost":"cerstve","cena_v_recepte":0.48,"usetris_v_recepte":0.