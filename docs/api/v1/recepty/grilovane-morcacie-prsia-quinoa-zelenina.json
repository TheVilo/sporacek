{"slug":"grilovane-morcacie-prsia-quinoa-zelenina","nazov":"Grilované morčacie prsia s quinoa a grilovanou zeleninou","porcie":2,"cas_pripravy":"40 minút","foto_url":"https://raw.githubusercontent.com/TheVilo/sporacek/main/fotky/grilovane-morcacie-prsia-quinoa-zelenina.jpg","tagy":["večera","morčacie","vysoký-proteín","ľahké"],"suroviny":[{"nazov":"Morčacie prsia","mnozstvo":"400 g","id":"morcacie-prsia","qty":400.0,"jednotka":"g","mnozstvo_g":400},{"nazov":"Quinoa","mnozstvo":"150 g","id":"quinoa","qty":150.0,"jednotka":"g","mnozstvo_g":150},{"nazov":"Cuketa","mnozstvo":"1 ks","id":"cuketa","qty":1.0,"jednotka":"ks","mnozstvo_g":300},{"nazov":"Paprika","mnozstvo":"1 ks","id":"paprika","qty":1.0,"jednotka":"ks","mnozstvo_g":150},{"nazov":"Cherry paradajky","mnozstvo":"150 g","id":"cherry-paradajky","qty":150.0,"jednotka":"g","mnozstvo_g":150},{"nazov":"Olivový olej","mnozstvo":"3 PL","id":"olivovy-olej","qty":45.0,"jednotka":"ml","mnozstvo_g":45},{"nazov":"Citrón","mnozstvo":"½ ks (šťava)","id":"citron","qty":0.5,"jednotka":"ks","mnozstvo_g":50},{"nazov":"Cesnak","mnozstvo":"2 strúčiky","id":"cesnak","qty":2.0,"jednotka":"ks","mnozstvo_g":10},{"nazov":"Oregano","mnozstvo":"1 ČL","id":"oregano","qty":5.0,"jednotka":"g","mnozstvo_g":5},{"nazov":"Soľ, čierne korenie","mnozstvo":"—","id":"cierne-korenie","qty":2,"jednotka":"g","mnozstvo_g":2}],"postup":["Quinou dôkladne prepláchni pod studenou vodou (odstráni horkastú chuť), uvar podľa návodu (pomer cca 1:2 s vodou, 15 minút, potom nechaj 5 minút postáť pod pokrievkou).","Morčacie prsia rozkroj vodorovne na tenšie plátky, potri zmesou oleja, prelisovaného cesnaku, oregana, soli a korenia. Nechaj 10 minút marinovať.","Cuketu a papriku nakrájaj na hrubšie plátky/prúžky.","Na rozohriatej grilovacej panvici opekaj morčacie prsia 4–5 minút z každej strany, kým nie sú prepečené a majú pekné grilovacie pásiky. Nechaj 5 minút odpočívať, potom nakrájaj na plátky.","Na tej istej panvici opeč cuketu, papriku a cherry paradajky 5–6 minút, kým zmäknú a mierne zoškvarnú.","Servíruj morčacie prsia na quinoi, obložené grilovanou zeleninou, pokvapkané citrónovou šťavou."],"nutricne":{"kcal":460,"bielkoviny_g":42,"sacharidy_g":40,"tuky_g":14},"alergeny":[],"vegetarianske":false,"veganske":false,"sezonne_suroviny":[{"id":"cuketa","mesiace":[6,7,8,9]},{"id":"paprika","mesiace":[7,8,9]},{"id":"cherry-paradajky","mesiace":[6,7,8,9]}],"ceny_za_porciu":[{"obchod":"Lidl","cena_za_porciu":3.33,"usetris_za_porciu":0.57,"napar_surovin":10,"z_letaku":7,"odhadom":3,"spolu_surovin":10,"spolahlive":true,"platnost_od":"2026-07-16","platnost_do":"2026-07-19","nakup":[{"id":"morcacie-prsia","surovina":"morčacie prsia","kupit":"Morčacie prsné rezne","zdroj_ceny":"letak","balenie":"cena za 1 kg","balenie_qty":1000,"balenie_jednotka":"g","cena_balenia":7.99,"povodna_cena":9.49,"akcia":true,"podmienka":null,"trvanlivost":"cerstve","cena_v_recepte":3.2,"usetris_v_recepte":0.6,"mnozstvo_g":400},{"id":"quinoa","surovina":"quinoa","kupit":null,"zdroj_ceny":"bezna","balenie":"500 g","balenie_qty":500.0,"balenie_jednotka":"g","cena_balenia":3.5,"povodna_cena":null,"akcia":false,"podmienka":null,"trvanlivost":"trvanlive","cena_v_recepte":1.05,"usetris_v_recepte":null,"mnozstvo_g":150},{"id":"cuketa","surovina":"cuketa","kupit":"Cuketa","zdroj_ceny":"letak","balenie":"cena za 1 kg","balenie_qty":1000,"balenie_jednotka":"g","cena_balenia":0.99,"povodna_cena":1.99,"akcia":true,"podmienka":"s Lidl Plus: 0.89 (-55%)","trvanlivost":"cerstve","cena_v_recepte":0.3,"usetris_v_recepte":0.3,"mnozstvo_g":300},{"id":"paprika","surovina":"paprika","kupit":"Červená paprika","zdroj_ceny":"letak","balenie":"cena za 1 kg","balenie_qty":1000,"balenie_jednotka":"g","cena_balenia":2.19,"povodna_cena":3.69,"akcia":true,"podmienka":null,"trvanlivost":"cerstve","cena_v_recepte":0.33,"usetris_v_recepte":0.23,"mnozstvo_g":150},{"id":"cherry-paradajky","surovina":"cherry paradajky","kupit":"Cherry paradajky strapcové","zdroj_ceny":"letak","balenie":"45