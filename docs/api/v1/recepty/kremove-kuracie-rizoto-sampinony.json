ta.","popis":"Pridaj kuracie stehná nakrájané na kocky, opeč zo všetkých strán do zlatista (5–6 minút). Vyber z hrnca a odlož nabok."},{"nadpis":"Opeč šampiňóny a ryžu (tostatúra).","popis":"Do toho istého hrnca pridaj nakrájané šampiňóny, opekaj na vyššom ohni 5 minút, kým pustia vodu a tá sa odparí. Vsyp ryžu, opekaj 2 minúty za stáleho miešania, kým nie sú zrniečka horúce a mierne sklovité.","tip":"Tento krok sa volá tostatúra — je základom krémovej textúry rizota."},{"nadpis":"Postupne prilievaj vývar, kým ryža nie je al dente.","popis":"Prilievaj horúci vývar naberačku po naberačke, za stáleho miešania. Vždy počkaj, kým sa tekutina takmer celá vstrebe, až potom prilej ďalšiu.","timer_min":20},{"nadpis":"Vmiešaj maslo a parmezán (mantecatura), vráť kura naspäť.","popis":"Keď je ryža al dente a rizoto má hustú, tečúcu konzistenciu, vráť kura do hrnca a odstav z ohňa. Vmiešaj studené maslo nakrájané na kocky a parmezán rázným miešaním — vznikne lesklá, krémová textúra úplne bez smotany.","tip":"Tento krok sa volá mantecatura. Miešaj energicky, kým sa maslo úplne nevmieša.","foto":"fotky/postup/kremove-kuracie-rizoto-sampinony-krok-5.jpg","foto_caption":"takto má vyzerať správna lesklá textúra"},{"nadpis":"Dochuť a podávaj.","popis":"Dochuť soľou a korením, nechaj minútu odstáť. Podávaj hneď, posypané petržlenovou vňaťou a ďalším parmezánom."}],"nutricne":{"kcal":540,"bielkoviny_g":35,"sacharidy_g":58,"tuky_g":17},"alergeny":["laktoza","zeler"],"vegetarianske":false,"veganske":false,"sezonne_suroviny":[],"ceny_za_porciu":[{"obchod":"Kaufland","cena_za_porciu":1.69,"usetris_za_porciu":0.63,"napar_surovin":12,"z_letaku":8,"odhadom":4,"spolu_surovin":12,"spolahlive":true,"platnost_od":"2026-07-16","platnost_do":"2026-07-22","nakup":[{"id":"kuracie-stehna","surovina":"kuracie stehná","kupit":"Kuracie horné alebo dolné stehná","zdroj_ceny":"letak","balenie":"cena za 1 kg","balenie_qty":1000,"balenie_jednotka":"g","cena_balenia":2.55,"povodna_cena":3.99,"akcia":true,"pod